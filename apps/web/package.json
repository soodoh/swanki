{
	"name": "web",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --bun vite dev",
		"build": "bun --bun vite build",
		"start": "bun .output/server/index.mjs",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "bun --bun vitest run --coverage",
		"test:ci": "bun --bun vitest run --project browser --shard 1/3 && bun --bun vitest run --project browser --shard 2/3 && bun --bun vitest run --project browser --shard 3/3 && bun --bun vitest run --project unit --coverage",
		"db:generate": "bun --bun x drizzle-kit generate",
		"db:push": "bun --bun x drizzle-kit push",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"postinstall": "cp node_modules/sql.js/dist/sql-wasm.wasm public/sql-wasm.wasm 2>/dev/null || true"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@better-auth/electron": "^1.6.23",
		"@capacitor-community/sqlite": "^8.1.0",
		"@capacitor/core": "^8.4.1",
		"@capacitor/filesystem": "^8.1.2",
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@fontsource-variable/geist": "^5.2.9",
		"@swanki/core": "workspace:*",
		"@tailwindcss/vite": "^4.3.2",
		"@tanstack/react-query": "^5.101.2",
		"@tanstack/react-router": "^1.170.17",
		"@tanstack/react-start": "^1.168.27",
		"@uiw/react-codemirror": "^4.25.11",
		"better-auth": "^1.6.23",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"drizzle-orm": "^0.45.2",
		"embla-carousel-react": "^8.6.0",
		"fflate": "^0.8.3",
		"fzstd": "^0.1.1",
		"isomorphic-dompurify": "^3.18.0",
		"lucide-react": "^0.577.0",
		"nitro": "^3.0.260311-beta",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"recharts": "^3.9.2",
		"shadcn": "^4.13.0",
		"sql.js": "^1.14.1",
		"tailwind-merge": "^3.6.0",
		"ts-fsrs": "^5.4.1",
		"tw-animate-css": "^1.4.0",
		"vite": "^8.1.4",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@types/dompurify": "^3.2.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/browser": "^4.1.10",
		"@vitest/browser-playwright": "^4.1.10",
		"@vitest/coverage-istanbul": "^4.1.10",
		"drizzle-kit": "^0.31.10",
		"playwright": "^1.61.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10",
		"vitest-browser-react": "^2.2.0"
	}
}
