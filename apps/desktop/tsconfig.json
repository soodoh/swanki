{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"paths": {
			"@/*": ["../web/src/*"],
			"@swanki/core/*": ["../../packages/core/src/*"]
		}
	},
	"include": ["electron/**/*.ts", "src/**/*.ts", "src/**/*.tsx"]
}
